# ── Snap2Sheet — Backend Config ───────────────────────────────────────────────

# LLMWhisperer API Key (REQUIRED)
# Get your FREE key at: https://unstract.com/llmwhisperer/
# Click "Get API Key" — free tier includes 100 pages/month
LLMWHISPERER_API_KEY=your_api_key_here

# LLMWhisperer base URL (leave as default)
# US:  https://llmwhisperer-api.us-central.unstract.com/api/v2
# EU:  https://llmwhisperer-api.eu-west.unstract.com/api/v2
LLMWHISPERER_BASE_URL=https://llmwhisperer-api.us-central.unstract.com/api/v2
